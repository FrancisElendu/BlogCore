{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=FRANCIS\\SQLEXPRESS;Initial Catalog=BlogPostCoreDb;Integrated Security=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "your-super-secret-key-with-at-least-32-characters-long",
    "Issuer": "BlogCoreAPI",
    "Audience": "BlogCoreClient",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Auth": {
    "AllowAdminRegistration": true, // Allow admin creation in dev environment but will be disabled in production ["Author", "Editor", "User"]
    "AllowedRoles": [ "Admin", "Author", "Editor", "User" ]
  }
}
